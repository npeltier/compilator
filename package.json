{
  "name": "compilator",
  "version": "1.0.0",
  "description": "Music compilation site for friends, hosted on Firebase.",
  "type": "module",
  "scripts": {
    "build": "cd functions && npm install && npm run build",
    "dev": "npx firebase emulators:start --only auth,functions,firestore,hosting,storage --project=demo-compilator --import=./emulator-data --export-on-exit",
    "dev:fresh": "npx firebase emulators:start --only auth,functions,firestore,hosting,storage --project=demo-compilator",
    "seed": "node scripts/seed.js",
    "test:e2e": "node test/e2e/upload-flow.test.mjs"
  },
  "devDependencies": {
    "firebase": "^12.14.0",
    "firebase-admin": "^12.1.0",
    "firebase-tools": "^15.19.0"
  },
  "author": "",
  "license": "ISC"
}
