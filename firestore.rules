rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function callerEmail() {
      return request.auth.token.email.lower();
    }

    function isAllowlisted() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/allowlist/$(callerEmail()));
    }

    // Admins can edit any compilation (not just their own). Membership is
    // managed via a Firestore-backed /admins/{emailLowercase} collection,
    // mirroring the /allowlist pattern.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(callerEmail()));
    }

    // Catalog version sentinel: a single doc holding monotonic revision
    // counters (coreRev for compilations+users, songsRev for songs). Bumped by
    // Firestore triggers (Admin SDK, bypassing rules) on any catalog write.
    // Allowlisted clients read it once per session to decide whether their
    // local Firestore cache is still fresh — see public/js/catalog.js.
    match /meta/{docId} {
      allow read: if isAllowlisted();
      allow write: if false;
    }

    // Allowlist: only Functions / admins write (via Admin SDK, bypassing rules).
    // Signed-in users can read their own entry so the client can check membership.
    match /allowlist/{email} {
      // Each user reads their own entry to check membership; admins can read
      // the whole collection so the assign-author dropdowns can list everyone.
      allow read: if isSignedIn()
                  && (callerEmail() == email || isAdmin());
      allow write: if false;
    }

    // Admins: same shape as /allowlist. Each user can read only their own entry
    // (to check if they're an admin); writes happen via Admin SDK.
    match /admins/{email} {
      allow read: if isSignedIn() && callerEmail() == email;
      allow write: if false;
    }

    // Access requests: signed-in-but-not-allowlisted users who tried to get in.
    // Written only by the requestAccess / approve / deny callables via the Admin
    // SDK (bypassing rules). Admins list them on the Membres screen.
    match /accessRequests/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // User profiles: doc id is the user's lowercased email — same id strategy
    // as /allowlist and /admins. Each user owns their own doc.
    match /users/{email} {
      allow read: if isAllowlisted();
      allow create: if isSignedIn() && callerEmail() == email;
      allow update: if isSignedIn() && callerEmail() == email
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'avatarPath', 'updatedAt']);
      allow delete: if false;

      // Per-user emoji reactions on songs: { emojis: string[], at }. A user can
      // apply several emojis to one song. Any allowlisted user can read them so
      // the author-profile page can surface "ses coups de cœur" and the song
      // rows can show the community aggregate; only the owning user can write
      // their own reactions. Legacy docs ({ value: 'like'|'dislike' }) are still
      // readable and normalized client-side. Friends-only site, accepted tradeoff.
      match /reactions/{songId} {
        allow read: if isAllowlisted();
        allow write: if isSignedIn() && callerEmail() == email;
      }

      // Per-user ❤️ likes on whole compilations. Same access shape as
      // reactions: any allowlisted user can read (so an author page could
      // surface "ses compilations aimées"), only the owner can write.
      match /likedCompilations/{compId} {
        allow read: if isAllowlisted();
        allow write: if isSignedIn() && callerEmail() == email;
      }

      // Per-user saved filter presets: { name, inc, exc, at }. Private to the
      // owner — they only drive the owner's own home-view shuffle buttons.
      match /savedFilters/{filterId} {
        allow read: if isSignedIn() && callerEmail() == email;
        allow write: if isSignedIn() && callerEmail() == email;
      }

      // Per-user private secrets, e.g. /private/discogs = { token, updatedAt }.
      // Owner-only read/write — never readable by other users. Cloud Functions
      // (Admin SDK) bypass these rules to read the token for enrichment, and to
      // fall back to an admin's token when the uploader has none.
      match /private/{doc} {
        allow read, write: if isSignedIn() && callerEmail() == email;
      }
    }

    // Compilations: allowlisted users read; the owning user (author == email)
    // or an admin can update/delete. Creates require the doc's `author` to be
    // the caller's email — admins create under their own email like everyone else.
    match /compilations/{compId} {
      allow read: if isAllowlisted();
      allow create: if isAllowlisted()
                    && (request.resource.data.author == callerEmail() || isAdmin());
      allow update: if isAllowlisted()
                    && (resource.data.author == callerEmail() || isAdmin());
      allow delete: if isAllowlisted()
                    && (resource.data.author == callerEmail() || isAdmin());

      // Songs subcollection: each compilation owns its songs. Written by
      // Functions during processSong, readable by allowlisted users. The
      // compilation's author OR an admin may also reorder / edit / delete
      // songs directly (for client-side editing).
      match /songs/{songId} {
        allow read: if isAllowlisted();
        allow write: if isAllowlisted()
                     && (get(/databases/$(database)/documents/compilations/$(compId)).data.author == callerEmail()
                         || isAdmin());
      }
    }

    // Collection-group read for `songs` so the client can build the catalog
    // in one query instead of N+1. Per-compilation song writes are gated above.
    match /{path=**}/songs/{songId} {
      allow read: if isAllowlisted();
    }

    // Collection-group read for `reactions` so the client can aggregate the
    // community emoji reactions across all users in one query. Per-user writes
    // stay gated under /users/{email}/reactions above.
    match /{path=**}/reactions/{songId} {
      allow read: if isAllowlisted();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
